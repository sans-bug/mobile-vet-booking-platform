# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/vetconnect

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Stripe Payment Gateway (Set mock to true to bypass external API checks)
MOCK_STRIPE=true
STRIPE_SECRET_KEY=sk_test_mock_stripe_key_change_me
STRIPE_WEBHOOK_SECRET=whsec_mock_webhook_key_change_me

# Azure Blob Storage Configuration (Set mock to true to store files locally in /uploads)
MOCK_AZURE_STORAGE=true
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=mockaccount;AccountKey=mockkey;EndpointSuffix=core.windows.net
AZURE_CONTAINER_NAME=petreports

# Google Authentication
GOOGLE_CLIENT_ID=your_google_client_id_here
